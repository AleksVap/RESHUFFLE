{
  "dataset": "InductiveFB15k237",
  "dataset_version": "v2",
  "dataset_kwargs": {
    "create_inverse_triples": true
  },
  "model": "RESHUFFLE",
  "model_kwargs": {
    "num_layers": [3],
    "l": [30],
    "k": [60],
    "dropout": 0,
    "aggregation_mode": "max_self_and_selfLoop"
  },
  "loss": "MarginRankingLoss",
  "loss_kwargs": {
    "margin": [1.0],
    "reduction": "mean"
  },
  "optimizer": "Adam",
  "optimizer_kwargs": {
    "lr": [0.005]
  },
  "negative_sampler": "BasicNegativeSampler",
  "negative_sampler_kwargs": {
    "num_negs_per_pos": 100
  },
  "training_kwargs": {
    "num_epochs": 1000,
    "checkpoint_frequency": 60,
    "checkpoint_name": "checkpoint.pt",
    "checkpoint_on_failure": true,
    "batch_size": 1024
  },
  "stopper": "early",
  "stopper_kwargs": {
    "patience": 10,
    "relative_delta": 0.01,
    "frequency": 10
  },
  "evaluator_kwargs": {
    "batch_size": 10
  }
}